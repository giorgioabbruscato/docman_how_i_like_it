{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "Database": {
    "ConnectionString": "Host=localhost;Port=5432;Database=hrportal;Username=hrportal;Password=hrportal"
  },
  "Keycloak": {
    "Authority": "http://localhost:8080/realms/hrportal",
    "Audience": "hrportal-api",
    "RequireHttpsMetadata": false
  },
  "Tenancy": {
    "TenantHeaderName": "X-Tenant-Id",
    "UseSubdomainResolution": false,
    "BaseDomain": "hrportal.local"
  },
  "Storage": {
    "RootPath": "./storage"
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:5173", "http://localhost:3000"]
  },
  "AllowedHosts": "*"
}
