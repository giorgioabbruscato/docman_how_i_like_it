# API base URL (required in production builds)
VITE_API_BASE_URL=/api

# Keycloak OIDC (required)
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=hrportal
VITE_KEYCLOAK_CLIENT_ID=hrportal-web

# Tenancy mode: single | multi (default: multi)
# - single: OSS single-tenant — no X-Tenant-Id header; VITE_TENANT_ID not required
# - multi:  SaaS multi-tenant — sends X-Tenant-Id on every API request
# VITE_TENANCY_MODE=single

# Tenant slug for multi mode only (required in production when VITE_TENANCY_MODE=multi)
VITE_TENANT_ID=demo
