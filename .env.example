# Copy to .env before running docker compose: cp .env.example .env
# Rotate all values before production deployment.

# Database (required)
POSTGRES_DB=hrportal
POSTGRES_USER=hrportal
POSTGRES_PASSWORD=change-me-in-production

# Keycloak admin (required — rotate after first login)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-in-production

# Keycloak API client secret (dev realm-export uses hrportal-api-secret; override in production)
KEYCLOAK_API_CLIENT_SECRET=hrportal-api-secret

# Backend
ASPNETCORE_ENVIRONMENT=Development

# Frontend build args (docker compose frontend service)
VITE_API_BASE_URL=http://localhost:5000/api
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=hrportal
VITE_KEYCLOAK_CLIENT_ID=hrportal-web
VITE_TENANT_ID=demo

# Production-only (docker-compose.prod.yml)
# KC_HOSTNAME=hrportal.example.com
# CORS_ALLOWED_ORIGINS=https://hrportal.example.com
